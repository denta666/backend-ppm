generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())

  @@map("contacts")
}

model Review {
  id        String   @id @default(cuid())
  name      String
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  @@map("reviews")
}

model Menu {
  id          String   @id @default(cuid())
  name        String
  category    String
  price       Int
  description String
  image       String
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("menus")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())

  @@map("admins")
}

model Gallery {
  id        String   @id @default(cuid())
  title     String
  category  String
  image     String
  createdAt DateTime @default(now())

  @@map("galleries")
}